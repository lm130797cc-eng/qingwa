# .env 文件配置示例 - 数据库隔离方案

# 现有项目 Key（建议设置为只读权限，避免误写现有数据）
# 对应 Schema: public / ants_mayijun
SUPABASE_MAYIJUN_URL=https://xxx.supabase.co
SUPABASE_MAYIJUN_ANON_KEY=eyJ...  # 仅 SELECT 权限

# 蚂蚁岛 Key（读写权限，独立 Service Role 或 限制 Schema 的 Key）
# 对应 Schema: ants_mayidao
SUPABASE_MAYIDAO_URL=https://xxx.supabase.co   # 同Project URL
SUPABASE_MAYIDAO_ANON_KEY=eyJ...  # 在 Supabase 后台创建新 Key 时，限制仅能访问 ants_mayidao schema
SUPABASE_MAYIDAO_SERVICE_KEY=eyJ...  # 后端专用 (service_role)，拥有绕过 RLS 的权限，请妥善保管
