{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/track",
      "destination": "https://mayidao-automation.n8n.cloud/webhook/track"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}